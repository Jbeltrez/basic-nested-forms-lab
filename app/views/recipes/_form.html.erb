<%= form_for(@recipe) do |f| %> 
    <%= f.label :title %> 
    <%= f.text_field :title %><br>

    <%= f.fields_for :ingredients do |i| %>
    
        <%= i.label :ingredient_name %> 
        <%= i.text_field :name %><br>

        <%= i.label :ingredient_quantity %>
        <%= i.text_field :quantity %><br>

        


        <!-- <input name="recipe[recipe_ingredients][]" id="recipe_ingredients_attributes_0_name">
        <input name="recipe[recipe_ingredients][]" id="recipe_ingredients_attributes_1_name">
        <input name="recipe[recipe_ingredients][]" id="recipe_ingredients_attributes_0_quantity">
        <input name="recipe[recipe_ingredients][]" id="recipe_ingredients_attributes_1_quantity"> -->
        
    <% end %> 
    <%= f.submit %>

<% end %> 
